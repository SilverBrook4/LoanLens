{% extends 'base.jinja' %}

{% block body %}
  <div>
    {% if user %}
      Logged in as {{ user.email }} | <a href="/logout">Logout</a>
    {% else %}
      <a href="/login">Login</a> | <a href="/register">Register</a>
    {% endif %}
  </div>
  <header>
    <h1>{{user.given_name}}'s Financial Dashboard</h1>
    <p>Overview of your loan portfolio</p>
  </header>

  <main>
    <section>
      <h2>Job Opportunities</h2>
      <p>Explore job listings related to your career</p>
      <div>
        <a href="/jobs">View Job Listings →</a>
      </div>
    </section>

    <section class="loan_distribution">
      <h2>Loans Distribution</h2>
      <p>Breakdown by loan status</p>
      <div>
        <canvas id="loansPieChart"></canvas>
      </div>
    </section>

    <section class="loan_summary">
      <h2>Loan Summary</h2>
      <p>Key metrics at a glance</p>
      <div>
        <div>
          <div id="totalLoans">
          {% if loan_summary %}
            {{loan_summary['num_loans']}}
          {% else %}
            No Loan Data to Display
          {% endif %}
          </div>
          <div>Total Loans</div>
        </div>
        <div>
          <div id="totalAmount">
          {% if loan_summary %}
            {{loan_summary['total_amount']}}
          {% else %}
            No Loan Data to Display
          {% endif %}
          </div>
          <div>Total Amount</div>
        </div>
        <div>
          <div id="activeLoans">
          {% if loan_summary %}
            {{loan_summary['active_loans']}}
          {% else %}
            No Loan Data to Display
          {% endif %}</div>
          <div>Active Loans</div>
        </div>
        <div>
          <div id="avgLoan">
          {% if loan_summary %}
            {{loan_summary['avg_loan']}}
          {% else %}
            No Loan Data to Display
          {% endif %}
          </div>
          <div>Avg Loan Size</div>
        </div>
      </div>
      <!-- add loan form -->
      <details>
        <summary role="button" class="addloan">Add New Loan</summary>
        <form action="/loan_create" method="POST">

          <label for="loan_name">Loan Name
            <input type="text" id="loan_name" name="loan_name" required>
          </label>

          <label for="loan_type">Loan Type
            <select id="loan_type" name="loan_type" required>
              <option value="student">Student</option>
              <option value="mortgage">Mortgage</option>
              <option value="auto">Auto</option>
              <option value="personal">Personal</option>
              <option value="other">Other</option>
            </select>
          </label>

          <label for="p_amount">Principal Amount ($)
            <input type="number" id="p_amount" name="p_amount" step="0.01" min="0" required>
          </label>

          <label for="ir">Interest Rate (%)
            <input type="number" id="ir" name="ir" step="0.01" min="0" required>
          </label>

          <label for="it">Interest Type
            <select id="it" name="it" required>
              <option value="fixed">Fixed</option>
              <option value="variable">Variable</option>
            </select>
          </label>

          <label for="term_length">Term Length (months)
            <input type="number" id="term_length" name="term_length" min="1" required>
          </label>

          <label for="min_payment">Minimum Payment ($)
            <input type="number" id="min_payment" name="min_payment" step="0.01" min="0" required>
          </label>

          <label for="late_fee">Late Fee ($)
            <input type="number" id="late_fee" name="late_fee" step="0.01" min="0" value="0">
          </label>

          <label for="amount_payed">Amount Already Paid ($)
            <input type="number" id="amount_payed" name="amount_payed" step="0.01" min="0" value="0">
          </label>

          <button type="submit">Add Loan</button>
        </form>
      </details>
    </section>

    <section class="monthly_goal">
      <h2>Monthly Goal Progress</h2>
      <p>Current progress towards monthly target</p>
      <div>
        <label for="monthlyGoal">Monthly Goal: $50,000 / $100,000</label>
        <progress id="monthlyGoal" value="50000" max="100000">50%</progress>
        <span>50%</span>
      </div>
    </section>

    <section class="loan_progress">
      <h2>Loan Completion Progress</h2>
      <p>Progress towards completing all loans</p>
      <div>
        <label for="loanCompletion">Completed: 67 / 100 loans</label>
        <progress id="loanCompletion" value="67" max="100">67%</progress>
        <span>67%</span>
      </div>
    </section>

    <section class="checklist">
      <h2>Completion Checklist</h2>
      <p>Track your loan processing tasks</p>
      <div>
        {% if goals %}
        {% for goal in goals%}
          <form action="/goal_status" method="POST" style="margin: 0;">
            <input type="hidden" name="goal_id" value="{{ goal['id'] }}">
            <input type="hidden" name="current_status" value="{{ goal['status'] }}">
            
            <button type="submit" 
                    class="{% if goal['status'] == 1 %}success{% else %}secondary outline{% endif %}" 
                    style="padding: 5px 15px; font-size: 0.9rem; min-width: 120px;">
              {% if goal['status'] == 1 %} Mark Incomplete {% else %} Mark Complete {% endif %}
            </button>
          </form>

          <span style="{% if goal['status'] == 1 %}text-decoration: line-through; opacity: 0.6;{% endif %}">
            {{ goal['description'] }}
          </span>

          <form action="/delete_goal" method="POST" style="margin: 0;">
            <input type="hidden" name="goal_id" value="{{ goal['id'] }}">
            <button type="submit" class="outline secondary" style="padding: 2px 10px; font-size: 0.8rem;">Delete</button>
          </form>
        {% endfor %}
        {% endif %}
        <!--
        <div>
          <input type="checkbox" id="check1" name="checklist">
          <label for="check1">Review pending loan applications</label>
        </div>
        <div>
          <input type="checkbox" id="check2" name="checklist" checked>
          <label for="check2">Process approved loans</label>
        </div>
        <div>
          <input type="checkbox" id="check3" name="checklist">
          <label for="check3">Update loan documentation</label>
        </div>
        <div>
          <input type="checkbox" id="check4" name="checklist">
          <label for="check4">Send payment reminders</label>
        </div>
        <div>
          <input type="checkbox" id="check5" name="checklist" checked>
          <label for="check5">Generate monthly reports</label>
        </div>
        <div>
          <input type="checkbox" id="check6" name="checklist">
          <label for="check6">Verify loan completion status</label>
        </div>
      -->
      </div>
      <details>
        <summary role="button" class="addgoal">Add New Goal</summary>
        <form action="/goal_create" method="POST">
            <label for="goal">
                Goal
                <input type="text" id="goal" name="goal" required>
            </label>
            
            <label for="duration">
                Duration
                <input type="int" id="duration" name="duration" required>
            </label>

            <label for="status">
                complete?
                <input type="checkbox" id="status" name="status", value='yes'>
            </label>

            <button type="submit">Submit</button>
        </form>
      </details>
    </section>
  </main>
{% endblock %}
