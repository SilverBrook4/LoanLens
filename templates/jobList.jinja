{% extends 'base.jinja' %}

{% block body %}
  <div>
    {% if user %}
      Logged in as {{ user.email }} | <a href="/logout">Logout</a>
    {% else %}
      <a href="/login">Login</a> | <a href="/register">Register</a>
    {% endif %}
  </div>

  <header>
    <h1>Job Listings</h1>
    <p>Job opportunities related to your career: <strong>{{ career|default('Your Career') }}</strong></p>
  </header>

  <main>
    {% if jobs and jobs|length > 0 %}
      <section>
        <h2>Found {{ jobs|length }} job listing(s)</h2>
        
        <div>
          {% for job in jobs %}
            <article>
              <h3>
                <a href="{{ job.url|default('#') }}" target="_blank" rel="noopener noreferrer">
                  {{ job.jobtitle|default(job.title|default('Job Title')) }}
                </a>
              </h3>
              
              <div>
                <p><strong>Company:</strong> {{ job.company|default('Not specified') }}</p>
                <p><strong>Location:</strong> {{ job.formattedLocation|default(job.city|default('') + ', ' + job.state|default(''))|default('Location not specified') }}</p>
                
                {% if job.salary %}
                  <p><strong>Salary:</strong> {{ job.salary }}</p>
                {% endif %}
                
                {% if job.date %}
                  <p><strong>Posted:</strong> {{ job.formattedRelativeTime|default(job.date) }}</p>
                {% endif %}
                
                {% if job.snippet %}
                  <div>
                    <p><strong>Description:</strong></p>
                    <p>{{ job.snippet|safe }}</p>
                  </div>
                {% elif job.description %}
                  <div>
                    <p><strong>Description:</strong></p>
                    <p>{{ job.description|safe }}</p>
                  </div>
                {% endif %}
                
                {% if job.sponsored %}
                  <span>Sponsored</span>
                {% endif %}
                
                {% if job.url %}
                  <div>
                    <a href="{{ job.url }}" target="_blank" rel="noopener noreferrer">
                      View on Indeed →
                    </a>
                  </div>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% else %}
      <section>
        <p>No job listings found for your career field.</p>
        <p>Try adjusting your search criteria or check back later.</p>
      </section>
    {% endif %}

    {% if error %}
      <section>
        <p><strong>Error:</strong> {{ error }}</p>
        <p>Unable to fetch job listings. Please try again later.</p>
      </section>
    {% endif %}
  </main>
{% endblock %}
